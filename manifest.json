{
  "manifest_version": 3,
  "name": "Pixel Bar",
  "version": "0.2.1",
  "description": "A powerful sidebar with vertical tabs, bookmarks, saved tab groups, and recently closed tabs.",
  "permissions": [
    "tabs",
    "tabGroups",
    "bookmarks",
    "sessions",
    "storage",
    "sidePanel"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Pixel Bar",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
